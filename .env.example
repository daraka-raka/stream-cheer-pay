# Supabase (public keys - safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Mercado Pago (Client ID is public by OAuth design)
VITE_MP_CLIENT_ID=your-client-id-here

# Secrets (NEVER expose in frontend - Supabase Edge Functions only)
# Configure these in Project Settings > Edge Functions:
# SUPABASE_SERVICE_ROLE_KEY=
# MERCADOPAGO_ACCESS_TOKEN=
# MP_CLIENT_SECRET=
# MP_WEBHOOK_SECRET=
